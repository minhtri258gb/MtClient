{
	"editor.showFoldingControls": "always",
	"editor.folding": true,
	"editor.foldingStrategy": "auto",
	"explicitFolding.rules": {
		"*": {
			"begin": "{{{",
			"end": "}}}"
		},
		"javascript": [
			{
				"begin": "{",
				"end": "}",
				"foldEOF": true
			},
			{
				"begin": "`",
				"end": "`"
			},
			{
				"foldLastLine": true
			},
		],
		"markdown": [
			{
				"begin": "^(#+)\\s.*",
				"end": "^(?=#+\\s|$)"
			},
			{
				"foldLastLine": true
			},
		]
	},
	"markdown.validate.enabled": false,
	"favorites.sortOrder": "DESC"
}