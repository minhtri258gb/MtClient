{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build SCSS",
			"type": "shell",
			"command": "sass",
			"args": [
				"${file}",
				"${fileDirname}/${fileBasenameNoExtension}.css",
			]
		},
		{
			"label": "Git Sync",
			"type": "shell",
			"command": "TortoiseGitProc /command:sync /path:.",
			"options": { "env": { "PATH": "D:/Apps/TortoiseGit/bin;${env:PATH}" }}
		},
	]
}